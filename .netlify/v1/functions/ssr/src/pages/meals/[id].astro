---
import SingleViewLayout from "../../layouts/SingleViewLayout.astro"
import { fetchSingleMealById } from "../../js/meal_fetching.js"

const { id } = Astro.params

const singleMeal = await fetchSingleMealById(id)

// Add error handling
if (!singleMeal) {
  console.error("No meal found for ID:", id)
  return Astro.redirect("/meals")
}
---

<SingleViewLayout
  title={singleMeal.strMeal}
  src={singleMeal.strMealThumb}
  headingText={singleMeal.strMeal}
  alt={singleMeal.strMealAlternate || "Meal image is missing"}
  target="_blank"
  meal={singleMeal}
/>

<script>
  import { supabaseClient } from "../../js/supabase/supabase_client"

  document.addEventListener("DOMContentLoaded", () => {
    const urlHash = window.location.hash.slice(1)

    if (urlHash) {
      const targetComment = document.getElementById(urlHash)

      if (targetComment) {
        console.log("Found target comment: ", urlHash)

        window.addEventListener(
          "scrollend",
          () => {
            targetComment.classList.add("comment-focus")
          },
          { once: true },
        )

        // Ensure scroll to comment (even though the browser should automatically do this)
        targetComment.scrollIntoView({ behavior: "smooth", block: "center" })
      } else {
        console.log("Comment not found: ", urlHash)
      }
    }
  })
</script>
