---
import Hero from "../components/heroes/Hero.astro"
import { fetchSingleMealById } from "../js/meal_fetching"
import Layout from "./Layout.astro"

const { id } = Astro.params

const singleMeal = await fetchSingleMealById(id)
---

<Layout title={singleMeal.strMeal}>
  <Hero
    isSingleViewHero={true}
    src={singleMeal.strMealThumb}
    alt
    headingText={singleMeal.strMeal}
  />
</Layout>

