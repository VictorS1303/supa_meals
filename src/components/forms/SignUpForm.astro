---
import Form from "../../components/forms/Form.astro"
import Dialog from "../dialogs/Dialog.astro"
const registerInputs = [
  {
    type: "email",
    labelText: "E-mail",
    placeholder: "Enter e-mail",
    name: "email_input",
  },
  {
    type: "text",
    labelText: "Name",
    placeholder: "Enter full name",
    name: "full_name_input",
  },
  {
    type: "password",
    labelText: "Password",
    placeholder: "Enter password",
    name: "password_input",
  },
  {
    type: "password",
    labelText: "Repeat Password",
    placeholder: "Repeat password",
    name: "repeat_password_input",
  },
  {
    type: "file",
    labelText: "Profile image",
    id: "avatar_image_upload",
    name: "avatar_image_upload_input",
  },
]
---

<Form
  headingText="Sign up"
  inputs={registerInputs}
  buttonText="Sign up"
  id="sign_up_form"
  action="sign-up"
/>

<!-- Sign Up Success Message -->
<Dialog
  dialogMessageId="sign_up_dialog_message"
  id="sign_up_success_dialog"
  headingText="Registration Successful"
  isSuccess={true}
/>

<!-- Sign Up Failed Message -->
<Dialog
  id="sign_up_failed_dialog"
  headingText="Registration Failed"
  isSuccess={false}
/>

<script>
  import { registerAndLogin } from "../../js/supabase/supabase_methods"
  import { storeUsersInUsersTable } from "../../js/supabase/supabase_methods"
  import { openDialog } from "../../js/utils/animations.js"

  const signUpForm = document.querySelector("#sign_up_form")
  const signUpSuccessDialog = document.querySelector<HTMLDialogElement>(
    "#sign_up_success_dialog",
  )
  const signUpSuccessDialogParagraph = signUpSuccessDialog?.querySelector(
    ".dialog-message-text",
  )

  const signUpFailedDialog = document.querySelector<HTMLDialogElement>(
    "#sign_up_failed_dialog",
  )

  const signUpFailedDialogParagraph = signUpFailedDialog?.querySelector(
    ".dialog-message-text",
  )

  console.log(signUpFailedDialog)

  signUpForm?.addEventListener("submit", (e) => handleRegisterAndLogin(e))

  async function handleRegisterAndLogin(e) {
    e.preventDefault() // ✅ Prevent default form submission

    const formData = new FormData(signUpForm)
    const emailInput = formData.get("email_input")
    const fullNameInput = formData.get("full_name_input")
    const passwordInput = formData.get("password_input")
    const repeatPasswordInput = formData.get("repeat_password_input")
    const profileImageInput =
      signUpForm.elements["avatar_image_upload_input"]?.files[0]

    if (passwordInput !== repeatPasswordInput) {
      alert("Passwords do not match!")
      return
    }

    // Register and login user
    const result = await registerAndLogin(
      fullNameInput,
      emailInput,
      passwordInput,
      profileImageInput,
    )

    if (result.success) {
      // ✅ Store user correctly: pass name, email, password, avatarUrl
      const storeResult = await storeUsersInUsersTable(
        fullNameInput, // name
        emailInput, // email
        result.avatarUrl, // profile image
      )

      signUpSuccessDialog?.showModal()
      signUpSuccessDialogParagraph.textContent = `Successful registration for ${result.user?.user_metadata.username}!`

      if (storeResult?.length) {
        console.log("User stored in database successfully")
      } else {
        console.error("Failed to store user in database")
      }

      setTimeout(() => {
        window.location.href = "/dashboard"
      }, 2000)
    } else {
      signUpFailedDialog?.showModal()
      signUpFailedDialogParagraph.textContent = `Registration failed: ${result.signUpError}`
    }
  }
</script>
