---
import Button from "../buttons/Button.astro"
import LikeButton from "./LikeButton.astro"
import LikeAmount from "./LikeAmount.astro"

import { countLikes } from "../../js/supabase/supabase_methods"
const { class: className, id: id, likeAmount, userId, commentId } = Astro.props
const currentLikesAmount = await countLikes(commentId)
---

<article
  class={`like-counter-container flex gap-2 text-(--secondary-text-color) text-xl`}
  data-comment-author-id={userId}
  data-comment-id={commentId}
>
  <LikeButton userId={userId} commentId={commentId} />
  <span class="like-amount">{currentLikesAmount}</span>
</article>

<script>
  import { supabaseClient } from "../../js/supabase/supabase_client"
  import { countLikes } from "../../js/supabase/supabase_methods"
  import {
    likeComment,
    hasUserLikedComment,
    dislikeComment,
  } from "../../js/supabase/supabase_methods"
  import { createNotification } from "../../js/utils/notifications"

  const likesCounterContainers = document.querySelectorAll(
    ".like-counter-container",
  )

  // Get current user
  const {
    data: { session },
  } = await supabaseClient.auth.getSession()
  const currentUserId = session?.user?.id

  // Initialize likes on page load
  window.addEventListener("load", initializeCommentLikes)

  function initializeCommentLikes() {
    likesCounterContainers.forEach(async (likeCounterContainer) => {
      await updateLikesContainerUI(likeCounterContainer)
      await handleCommentLikeCheck(likeCounterContainer)

      likeCounterContainer.addEventListener("click", async (e) => {
        await handleCommentLike(e, likeCounterContainer)
      })
    })
  }

  function updateLikesContainerUI(container) {
    const commentAuthorId = container.dataset.commentAuthorId

    if (currentUserId && currentUserId === commentAuthorId) {
      container.style.opacity = "0.4"
      container.style.pointerEvents = "none"
    }
  }

  async function handleCommentLikeCheck(container) {
    if (!currentUserId) {
      return
    }

    const commentId = container.dataset.commentId
    const likeIcon = container.querySelector("i")
    const hasLiked = await hasUserLikedComment(currentUserId, commentId)

    container.dataset.hasLiked = hasLiked ? "true" : "false"

    if (hasLiked && likeIcon) {
      likeIcon.classList.remove("fa-regular")
      likeIcon.classList.add("fa-solid")
    } else if (likeIcon) {
      likeIcon.classList.remove("fa-solid")
      likeIcon.classList.add("fa-regular")
    }
  }

  async function handleCommentLike(e, likeCounterContainer) {
    // Step 0: Safety check for container
    if (!likeCounterContainer) return

    // Step 1: Get commentId safely
    const commentId = likeCounterContainer.dataset.commentId
    if (!commentId) {
      console.error("No comment data:", likeCounterContainer)
      return
    }

    // Step 2: Get the like icon
    const likeIcon = likeCounterContainer.querySelector("i")

    // Step 3: Check if user has already liked
    const hasLiked = await hasUserLikedComment(currentUserId, commentId)

    // Step 4: Insert or remove like
    let likeSuccess = false
    if (hasLiked) {
      // DISLIKE
      const { error } = await dislikeComment(currentUserId, commentId)
      likeSuccess = !error
    } else {
      // LIKE
      const { error } = await likeComment(currentUserId, commentId)
      likeSuccess = !error
    }

    if (!likeSuccess) {
      console.error("Failed to update like for comment:", commentId)
      return
    }

    // Step 5: Re-select container in case DOM changed
    const container = document.querySelector(
      `.like-counter-container[data-comment-id="${commentId}"]`,
    )
    if (!container) return

    // Step 6: Update the like count and icon in DOM
    await updateLikeCount(container)
    await handleCommentLikeCheck(container)
  }

  async function updateLikeCount(likeCounterContainer) {
    if (!likeCounterContainer) {
      console.log(
        "Like counter container not found - comment may have been deleted",
      )
      return
    }

    const commentId = likeCounterContainer.dataset.commentId
    const amountEl = likeCounterContainer.querySelector(".like-amount")

    if (!commentId || !amountEl) {
      return
    }

    const newCount = await countLikes(commentId)
    amountEl.textContent = newCount
  }

  // Handle likes in realtime
  const likesChannel = supabaseClient
    .channel("realtime-likes")
    .on(
      "postgres_changes",
      {
        event: "*",
        schema: "public",
        table: "likes",
      },
      async (payload) => {
        const commentId = payload.new?.comment_id || payload.old?.comment_id

        if (!commentId) {
          return
        }

        const likeCounterContainer = document.querySelector(`
          .like-counter-container[data-comment-id="${commentId}"]
      `)

        if (!likeCounterContainer) {
          console.log(
            "Target element not found - comment may have been deleted",
          )
          return
        }

        // Refetch like count
        await updateLikeCount(likeCounterContainer)

        // Update icon if current user triggered the change
        const userId = payload.new?.user_id || payload.old?.user_id

        if (userId === currentUserId) {
          await handleCommentLikeCheck(likeCounterContainer)
        }
      },
    )
    .subscribe()

  // Cleanup on page unload
  window.addEventListener("beforeunload", () => {
    supabaseClient.removeChannel(likesChannel)
  })
</script>
