---
import Button from "../buttons/Button.astro"
import LikeButton from "./LikeButton.astro"
import LikeAmount from "./LikeAmount.astro"

import { countLikes } from "../../js/supabase/supabase_methods"
const { class: className, id: id, likeAmount, userId, commentId } = Astro.props
const currentLikesAmount = await countLikes(commentId)
---

<article
  class={`like-counter-container flex gap-2 text-(--secondary-text-color) text-xl`}
  data-comment-author-id={userId}
  data-comment-id={commentId}
>
  <LikeButton userId={userId} commentId={commentId} />
  <span class="like-amount">{currentLikesAmount}</span>
</article>

<script>
  import { supabaseClient } from "../../js/supabase/supabase_client"
  import {
    likeComment,
    hasUserLikedComment,
    dislikeComment,
  } from "../../js/supabase/supabase_methods"

  const likesCounterContainers = document.querySelectorAll(
    ".like-counter-container",
  )

  window.addEventListener("load", initializeCommentLikes)

  // Get current user
  const {
    data: { session },
  } = await supabaseClient.auth.getSession()

  const currentUserId = session?.user?.id

  likesCounterContainers.forEach(async (likesCounterContainer) => {
    await updateLikesContainerUI(likesCounterContainer)
    await handleCommentLikeCheck(likesCounterContainer)

    likesCounterContainer.addEventListener("click", (e) =>
      handleCommentLike(e, likesCounterContainer),
    )
  })

  function initializeCommentLikes() {
    likesCounterContainers.forEach(async (likeCounterContainer) => {
      await updateLikesContainerUI(likeCounterContainer)
      await handleCommentLikeCheck(likeCounterContainer)

      likeCounterContainer.addEventListener("click", (e) => {
        handleCommentLike(e, likeCounterContainer)
      })
    })
  }

  function updateLikesContainerUI(container) {
    const commentAuthorId = container.dataset.commentAuthorId

    if (currentUserId && currentUserId === commentAuthorId) {
      container.style.opacity = "0.4"
      container.style.pointerEvents = "none"
    }
  }

  async function handleCommentLikeCheck(container) {
    if (!currentUserId) {
      return
    }

    const commentId = container.dataset.commentId
    const likeIcon = container.querySelector("i")

    const hasLiked = await hasUserLikedComment(currentUserId, commentId)

    container.dataset.hasLiked = hasLiked ? "true" : "false"

    if (hasLiked && likeIcon) {
      likeIcon.classList.remove("fa-regular")
      likeIcon.classList.add("fa-solid")
    }
  }

  async function handleCommentLike(e, likeCounterContainer) {
    if (!currentUserId) {
      return
    }

    const commentId = likeCounterContainer?.dataset?.commentId
    const likeIcon = likeCounterContainer?.querySelector("i")

    const hasLiked = await hasUserLikedComment(currentUserId, commentId)

    if (hasLiked) {
      // DISLIKE
      await dislikeComment(currentUserId, commentId)

      likeIcon.classList.remove("fa-solid")
      likeIcon.classList.add("fa-regular")
    } else {
      // LIKE
      await likeComment(currentUserId, commentId)
      likeCounterContainer.dataset.hasLiked = "true"

      likeIcon.classList.add("fa-solid")
      likeIcon.classList.remove("fa-regular")
    }
  }
</script>
