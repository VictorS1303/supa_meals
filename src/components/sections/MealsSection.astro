---
import Section from "./Section.astro"
import MealsContainer from "../containers/MealsContainer.astro"
const {class: className, id: id} = Astro.props

const mealCards = [
  {
    class: "meal-card",
    id: "meal_card",
    src: "https://images.unsplash.com/photo-1519708227418-c8fd9a32b7a2?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
    headingText: "Pasta with salmon",
    paragraphText: "Pasta with salmon is a dish with pasta and salmon",
    buttonText: "See Recipe",
  },
]
---


<Section class="meals-section" id="meals_section">
<MealsContainer mealCards={mealCards}/>
</Section>