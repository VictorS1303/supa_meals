---
import Section from "./Section.astro"
import UserDashboardInfo from "../user_info/UserDashboardInfo.astro"
import Notifications from "../notifications/Notifications.astro"
import Heading from "../headings/Heading.astro"
import { supabaseClient } from "../../js/supabase/supabase_client"

const { class: className, id: id } = Astro.props
---

<Section class={`${className}`} id={id}>
  <Heading variant="dashboard_heading">
    <h2 id="greeting"></h2>
  </Heading>
  <div class="flex flex-col gap-6 mt-8 md:flex-row md:justify-between">
    <!-- Notifications -->
    <Notifications />
    <!-- User info -->
    <UserDashboardInfo />
  </div>
</Section>

<script>
  import { supabaseClient } from "../../js/supabase/supabase_client"
  import { formatGreeting } from "../../js/utils/formatters.js"

  document.addEventListener("DOMContentLoaded", setUserInfoOnDashboard)

  async function setUserInfoOnDashboard() {
    await setGreeting()
    await setProfileImage()
  }

  async function setGreeting() {
    const greeting = document.querySelector("#greeting")
    const {
      data: { user },
    } = await supabaseClient.auth.getUser()

    console.log("Greeting - User object:", user)

    if (!greeting) {
      console.error("Greeting element not found")
      return
    }

    const username = user?.user_metadata?.username || user?.email?.split("@")[0]
    greeting.textContent = `${formatGreeting()}, ${username}`
  }

  async function setProfileImage() {
    const userProfileImage = document.querySelector("#user_profile_image")

    console.log("Image element:", userProfileImage)

    if (!userProfileImage) {
      console.error("Profile image element #user_profile_image not found")
      return
    }

    const {
      data: { user },
    } = await supabaseClient.auth.getUser()

    const imageUrl = user?.user_metadata?.avatar_url

    imageUrl ? (userProfileImage.src = imageUrl) : ""
  }
</script>
