---
import {
  fetchComments,
  resolveApiMealIdToInternalMealId,
} from "../../js/supabase/supabase_methods"
import Heading from "../headings/Heading.astro"
import Section from "./Section.astro"
import CommentCardsContainer from "../containers/CommentCardsContainer.astro"

const { mealId: apiMealId, headingText, class: className, id } = Astro.props

// Resolve API ID to internal PK
const internalMealId = await resolveApiMealIdToInternalMealId(apiMealId)

// Only fetch comments if we successfully resolved the internal ID
const comments = internalMealId ? await fetchComments(internalMealId) : []

console.log("API ID:", apiMealId, "Internal ID:", internalMealId)
console.log("Fetched comments:", comments)
---

<Section class={`${className} my-7`} id={id}>
  <Heading variant="comment_heading" slot="title">
    {headingText}
  </Heading>
  <CommentCardsContainer comments={comments} />
</Section>
