---
import Link from "../links/Link.astro"
import Heading from "../headings/Heading.astro"
import Paragraph from "../paragraphs/Paragraph.astro"
import Button from "../buttons/Button.astro"
import LikesCounter from "../likes/LikesCounter.astro"
import MealRatingContainer from "../containers/MealRatingContainer.astro"
import CommentCardBodyContainer from "../containers/CommentCardBodyContainer.astro"
import Footer from "../footers/Footer.astro"

const {
  class: className,
  id: id,
  isMealCard,
  href,
  buttonText,
  paragraphText,
  isCardParagraph,
  headingText,
  src,
  alt,
  meal,
  isLikedMealCard,
  isCommentCard,
  username,
  timeSincePost,
  likeAmount,
  starsCount,
  mealRatingNumber,
  maximumRatingNumber,
} = Astro.props
---

{
  isMealCard ? (
    <article
      class={`${className} w-full max-w-[300px] p-4 bg-white rounded-md flex flex-col`}
      id={id}
      data-meal-name={meal?.strMeal || ""}
    >
      <img src={src} class="rounded-tl-md rounded-tr-md w-full" />
      <Heading isCardHeading={true} headingText={headingText} />
      <Paragraph paragraphText={paragraphText} isCardParagraph={true} />
      <Link
        href={href}
        isMealCardLink={true}
        buttonText={buttonText}
        class="mt-auto"
      />
    </article>
  ) : isLikedMealCard ? (
    <article class="grid liked-meal-card relative w-[225px] h-[250px] overflow-hidden rounded-md group">
      <img src={src} alt={alt} class="h-full w-full object-cover" />
      <Heading isLikedMealCardHeading={true} headingText={headingText} />
      <Button isDislikeMealButton={true} />
    </article>
  ) : isCommentCard ? (
    <article class="flex flex-col gap-6 bg-white w-full p-4 rounded-md md:max-w-[400px]">
      <Heading
        isCommentCardHeading={true}
        src={src}
        alt={alt}
        username={username}
        timeSincePost={timeSincePost}
      />

      <CommentCardBodyContainer
        isCommentCardSubHeading={true}
        headingText={headingText}
        isCommentCardParagraph={true}
        paragraphText={paragraphText}
      />

      <Footer
        isCommentCardFooter={true}
        likeAmount={likeAmount}
        starsCount={starsCount}
        mealRatingNumber={mealRatingNumber}
        maximumRatingNumber={maximumRatingNumber}
      />
    </article>
  ) : (
    ""
  )
}
