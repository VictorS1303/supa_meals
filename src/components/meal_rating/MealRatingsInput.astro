---
const { class: className, id: id, maxStars } = Astro.props
const baseStarClasses = `absolute inset-0 w-full h-full`
const starsArray = Array.from({ length: maxStars })
---

<article class={`${className} meal-rating-stars-container my-4`}>
  <div
    class="meal-rating-star flex gap-3 cursor-pointer relative my-2"
    data-max-stars={maxStars}
  >
    {
      starsArray.map((star, index) => (
        <div class="star-wrapper relative w-8 h-8" data-star-index={index + 1}>
          {/* Background (empty star) */}
          <svg
            class={`${baseStarClasses} star-empty text-gray-300`}
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
          </svg>
          {/* Foreground (filled) star with clip path */}
          <svg
            class={`${baseStarClasses} star-filled text-(--secondary-text-color)`}
            fill="currentColor"
            viewBox="0 0 24 24"
            style="clip-path: inset(0 100% 0 0);"
          >
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
          </svg>
        </div>
      ))
    }
  </div>
</article>

<script>
  import { initializeMealRating } from "../../js/utils/rating_stars.js"
  initializeMealRating()
</script>
