---
const { videoId, videoTitle } = Astro.props

// Generate a unique ID for this instance to avoid conflicts
const playerId = `player-${videoId}`
---

<div class="video-container">
  <div class="plyr__video-embed" id={playerId}>
    <iframe
      src={`https://www.youtube.com/embed/${videoId}?modestbranding=1&playsinline=1`}
      allowfullscreen
      title={videoTitle}></iframe>
  </div>
</div>

<style>
  .video-container {
    width: 100%;
    max-width: 100%;
    aspect-ratio: 16/9;
    position: relative;
  }

  .plyr__video-embed,
  .plyr__video-embed iframe {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>

<script client:load>
  import Plyr from "plyr"

  // Initialize Plyr on this unique ID
  new Plyr(`#${playerId}`, {
    youtube: {
      noCookie: true,
      modestBranding: true,
    },
    controls: [
      "play",
      "progress",
      "current-time",
      "mute",
      "volume",
      "fullscreen",
    ],
  })
</script>
