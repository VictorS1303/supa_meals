---
const { class: className, id, variant = "single_view" } = Astro.props

const baseHeroClasses = "relative overflow-hidden"

const heroVariants = {
  landing: "h-screen w-screen",
  single_view: "mb-3 h-[300px] w-full",
  default: "h-screen max-h-[300px] w-full",
}

const heroClass = `${baseHeroClasses} ${heroVariants[variant]} ${className ?? ""}`
---

<section class={heroClass}>
  <!-- Background slot -->
  <slot name="background" />

  <!-- Overlay slot -->
  <slot name="overlay" />

  <!-- Backlink slot -->
  {
    variant === "single_view" && (
      <div class="absolute top-4 left-4 z-20">
        <slot name="backlink" />
      </div>
    )
  }

  <!-- Centered content slot -->
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-20 flex flex-col items-center gap-4 text-center"
  >
    <slot />
  </div>
</section>
