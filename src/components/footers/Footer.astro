---
import LikesAndRatingsContainer from "../containers/LikesAndRatingsContainer.astro"
const {
  class: className,
  id: id,
  isCommentCardFooter,
  likeAmount,
  starsCount,
  mealRatingNumber,
  maximumRatingNumber,
} = Astro.props
---

{
  isCommentCardFooter ? (
    <footer class={`${className} mt-auto`} id={id}>
      <LikesAndRatingsContainer
        likeAmount={likeAmount}
        starsCount={starsCount}
        mealRatingNumber={mealRatingNumber}
        maximumRatingNumber={maximumRatingNumber}
      />
    </footer>
  ) : (
    ""
  )
}
