---
import Button from "../buttons/Button.astro"
import Dialog from "../dialogs/Dialog.astro"
import Form from "../forms/Form.astro"
import Heading from "../headings/Heading.astro"
import Link from "../links/Link.astro"
import MealRatingsInput from "../meal_rating/MealRatingsInput.astro"
import Paragraph from "../paragraphs/Paragraph.astro"

const {
  class: className,
  id: id,
  mealInteractionButtons = [],
  mealInteractionButtonText,
  dataAction,
} = Astro.props
const { isLoggedIn } = Astro.props
---

<article class="flex items-center gap-12 mt-4">
  {
    mealInteractionButtons.length > 0 ? (
      mealInteractionButtons.map((mealInteractionButton) => {
        return (
          <Button
            variant="meal_interaction_button"
            data-action={mealInteractionButton.dataAction}
            class="meal-interaction-button"
          >
            <i class={`${mealInteractionButton.iconClass} text-2xl`} />
            <span class="text-md">
              {mealInteractionButton.mealInteractionButtonText}
            </span>
          </Button>
        )
      })
    ) : (
      <p>No available interactions</p>
    )
  }
</article>

<!-- Like Succes Dialog -->
<Dialog
  variant="liked_meal_dialog success"
  isClosableDialog={true}
  id="liked_meal_success_dialog"
>
  <Heading variant="dialog_heading" slot="title">
    <h2>Meal liked successfully!</h2>
  </Heading>
  <Paragraph slot="dialog-body-text" variant="dialog_paragraph">
    You can see your liked meals on your <Link
      variant="dialog_link"
      href="/dashboard">dashboard</Link
    >.
  </Paragraph>
</Dialog>

<!-- Already Liked Meal -->
<Dialog variant="danger" isClosableDialog={true} id="already_liked_meal_dialog">
  <Heading variant="dialog_heading" slot="title">
    <h2>Meal already liked</h2>
  </Heading>

  <Paragraph slot="dialog-body-text" variant="dialog_paragraph">
    You have already liked this meal. You can find it on your
    <Link variant="dialog_link" href="/dashboard">dashboard</Link>
  </Paragraph>
</Dialog>

<!-- Comment Dialog -->
<Dialog variant="success" isClosableDialog={true} id="comment_meal_dialog">
  <Form
    variant="comment"
    id="comment_meal_form"
    isDialogForm={true}
    slot="form"
  >
    <MealRatingsInput maxStars={5} />
  </Form>
</Dialog>

<script>
  import { supabaseClient } from "../../js/supabase/supabase_client"
  import {
    fetchLikedMealData,
    likeMeal,
    storeUsersInUsersTable,
    commentMeal,
    getMelPrimaryKeyByApiId,
    resolveApiMealIdToInternalMealId,
  } from "../../js/supabase/supabase_methods.js"

  const likedMealSuccessDialog = document.querySelector<HTMLDialogElement>(
    "#liked_meal_success_dialog",
  )

  const alreadyLikedMealDialog = document.querySelector<HTMLDialogElement>(
    "#already_liked_meal_dialog",
  )

  const commentMealDialog = document.querySelector("#comment_meal_dialog")
  const commentMealForm = document.querySelector("form#comment_meal_form")

  commentMealForm?.addEventListener("submit", (e) => handleCommentMeal(e))

  // Get meal ID from URL path
  const mealIdFromURL = window.location.pathname.split("/").pop()
  console.log("Meal ID from URL:", mealIdFromURL)

  const mealInteractionButtons = document.querySelectorAll(
    ".meal-interaction-button",
  )

  // Update UI state of the buttons based on login status
  function updateMealInteractionButtonsUI(isLoggedIn) {
    mealInteractionButtons.forEach((btn) => {
      if (isLoggedIn) {
        btn.classList.remove("disabled-interaction-button")
      } else {
        btn.classList.add("disabled-interaction-button")
      }
    })
  }

  // Attach click handlers
  mealInteractionButtons.forEach((btn) => {
    console.log("Attaching listener to mealInteractionButton:", btn)
    btn.addEventListener("click", async (e) => {
      console.log("Button clicked!")
      await handleMealInteraction(e.currentTarget)
    })
  })

  // Meal interaction handler
  async function handleMealInteraction(btnElement) {
    const action = btnElement.getAttribute("data-action")

    const {
      data: { session },
    } = await supabaseClient.auth.getSession()

    if (!session?.user) {
      alert("You must be logged in to interact with meals")
      return
    }

    const userId = session.user.id

    if (!userId) {
      alert("Could not determine your user ID. Please log in again.")
      return
    }

    // Ensure user exists in users table
    try {
      await storeUsersInUsersTable(
        session.user.user_metadata?.username || "",
        session.user.email,
        session.user.user_metadata?.avatar_url || null,
      )
    } catch (err) {
      console.error("Failed to store user in users table:", err)
      alert(
        "Could not prepare your account for liking meals. Please try again.",
      )
      return
    }

    if (action === "like") {
      if (!mealIdFromURL) {
        alert("Invalid meal ID. Cannot like this meal.")
        return
      }

      try {
        const likeResult = await likeMeal(userId, mealIdFromURL)
        if (likeResult?.alreadyLiked) {
          alreadyLikedMealDialog?.showModal()
        } else {
          likedMealSuccessDialog?.showModal()
        }
      } catch (err) {
        console.error("Error liking meal:", err)
        alert("Failed to like meal. Please try again.")
      }
    }

    if (action === "comment") {
      commentMealDialog?.showModal()
    }
  }

  // Handle meal commenting
  async function handleCommentMeal(e) {
    e.preventDefault()

    const formData = new FormData(commentMealForm)
    const commentTitle = formData.get("comment_title_input")
    const commentBody = formData.get("comment_text_input")
    const ratingRaw = formData.get("comment_rating_input")
    const ratingAsNumber = Number(ratingRaw)

    if (
      !commentTitle ||
      !commentBody ||
      Number.isNaN(ratingAsNumber) ||
      ratingAsNumber <= 0
    ) {
      alert("Please fill out all fields and rate the meal")
      return
    }

    const internalMealId = await resolveApiMealIdToInternalMealId(mealIdFromURL)

    // Resolve api_meal_id (from URL) to internal meal id
    // const { data: mealData, error: mealError } = await supabaseClient
    //   .from("meals")
    //   .select("id")
    //   .eq("api_meal_id", mealIdFromURL)
    //   .single()

    // if (!mealData || mealError) {
    //   console.error("No meal found for api_meal_id: ", mealIdFromURL)
    //   alert("Cannot submit comment: Meal not found!")
    //   return
    // }

    try {
      await commentMeal(internalMealId, {
        title: commentTitle,
        body: commentBody,
        rating: ratingAsNumber,
      })

      commentMealDialog?.close()
      commentMealForm?.reset()
    } catch (error) {
      console.error("Failed to submit comment: ", error)
      alert("Could not submit the comment!")
    }
  }

  // Check auth status on page load
  async function checkAuthStatus() {
    const {
      data: { session },
    } = await supabaseClient.auth.getSession()
    updateMealInteractionButtonsUI(!!session)
  }

  // Listen for auth state changes
  supabaseClient.auth.onAuthStateChange((event, session) => {
    updateMealInteractionButtonsUI(!!session)
  })

  checkAuthStatus()
</script>
