---
import Button from "../buttons/Button.astro"
const {
  class: className,
  id: id,
  mealInteractionButtons = [],
  mealInteractionButtonText,
  dataAction,
} = Astro.props
const { isLoggedIn } = Astro.props
---

<article class="flex items-center gap-12 mt-4">
  {
    mealInteractionButtons.length > 0 ? (
      mealInteractionButtons.map((mealInteractionButton) => {
        console.log("Button config:", mealInteractionButton) // DEBUG
        return (
          <Button
            isMealInteractionButton={true}
            dataAction={mealInteractionButton.dataAction}
          >
            <i class={`${mealInteractionButton.iconClass} text-2xl`} />
            <span class="text-md">
              {mealInteractionButton.mealInteractionButtonText}
            </span>
          </Button>
        )
      })
    ) : (
      <p>No available interactions</p>
    )
  }
</article>

<script>
  import { supabaseClient } from "../../js/supabase/supabase_client"
  import { fetchLikedMealData } from "../../js/supabase/supabase_methods"
  import { likeMeal } from "../../js/supabase/supabase_methods.js"

  // Get mea ID from URL path
  const singleViewPath = window.location.pathname.split("/")
  const mealIdFromURL = singleViewPath[singleViewPath.length - 1]
  console.log("Meal ID from URL:", mealIdFromURL)

  const mealInteractionButtons = document.querySelectorAll(
    ".meal-interaction-button",
  )

  // Update UI state of the buttons based on login status
  function updateMealInteractionButtonsUI(isLoggedIn) {
    mealInteractionButtons.forEach((mealInteractionButton) => {
      if (isLoggedIn) {
        mealInteractionButton.classList.remove("disabled-interaction-button")
      } else {
        mealInteractionButton.classList.add("disabled-interaction-button")
      }
    })
  }

  // Handle meal interactions
  mealInteractionButtons.forEach((mealInteractionButton) => {
    console.log(
      "Attaching listener to mealInteractionButton:",
      mealInteractionButton,
    ) // DEBUG
    mealInteractionButton.addEventListener("click", async (e) => {
      console.log("Button clicked!") // DEBUG
      await handleMealInteraction(e.currentTarget)
    })
  })

  // Meal interaction handler
  async function handleMealInteraction(mealInteractionButtonElement) {
    const mealInteractionAction =
      mealInteractionButtonElement.getAttribute("data-action")

    const {
      data: { session },
    } = await supabaseClient.auth.getSession()

    if (!session) {
      alert("You must be logged in to interact with meals")
      return
    }

    if (mealInteractionAction === "like") {
      const mealId = mealIdFromURL // API ID from URL

      if (!mealId) return

      try {
        const userId = session?.user?.id
        const likeResult = await likeMeal(userId, mealId) // ✅ API ID, function resolves DB ID
        if (likeResult.alreadyLiked) alert("Meal already liked")
        else alert("Meal liked successfully")
      } catch (likeMealError) {
        console.error("Error liking meal:", likeMealError)
      }
    }
  }

  // Check if user is logged in on page load
  async function checkAuthStatus() {
    const {
      data: { session },
    } = await supabaseClient.auth.getSession()
    updateMealInteractionButtonsUI(!!session)
  }

  // Listen for auth state changes
  supabaseClient.auth.onAuthStateChange((event, session) => {
    updateMealInteractionButtonsUI(!!session)
  })

  // Initialize on page load
  checkAuthStatus()
</script>
