---
import Heading from "../headings/Heading.astro"
import Paragraph from "../paragraphs/Paragraph.astro"
import Button from "../buttons/Button.astro"

const {
  class: className,
  id: id,
  paragraphText,
  isCommentCardParagraph,
  headingText,
  isCommentCardSubHeading,
} = Astro.props
---

<div class={`${className} comment-card-body-container`} id={id}>
  <Heading
    isCommentCardSubHeading={isCommentCardSubHeading}
    headingText={headingText}
  />
  <div>
    <div class="paragraph-wrapper collapsed">
      <Paragraph
        isCommentCardParagraph={isCommentCardParagraph}
        paragraphText={paragraphText}
        id="comment_card_body_paragraph"
      />
    </div>
    <Button
      isReadMoreButton={true}
      class="read-more-button"
      id="read_more_button"
      buttonText="Read more"
    />
  </div>
</div>

<style>
  .paragraph-wrapper {
    overflow: hidden;
    transition: max-height 0.35s ease;
    max-height: 4.5rem; /* roughly 3 lines */
  }

  .paragraph-wrapper.expanded {
    max-height: 1000px; /* something large enough */
  }
</style>

<script>
  // Find every card instance
  const containers = document.querySelectorAll(".comment-card-body-container")

  containers?.forEach((container) =>
    container.addEventListener("click", (e) => toggleCommentCardHeight(e)),
  )

  // Calculate collapsed height (4.5rem) in pixels using root font-size so it matches your CSS
  const rootFontSize =
    parseFloat(getComputedStyle(document.documentElement).fontSize) || 16
  const collapsedHeight = rootFontSize * 4.5 // 4.5rem

  function toggleCommentCardHeight(e) {
    const toggleButton = e.target.closest(".read-more-button")
    if (!toggleButton) return

    const commentParagraphWrapper = toggleButton.previousElementSibling
    const commentParagraph = commentParagraphWrapper.firstElementChild

    if (!commentParagraphWrapper || !commentParagraph) {
      return
    }

    // Toggle the expanded/collapsed classes
    const isExpanded = commentParagraphWrapper.classList.contains("expanded")

    if (isExpanded) {
      // Collapse it
      commentParagraphWrapper.classList.remove("expanded")
      commentParagraphWrapper.classList.add("collapsed")
      toggleButton.textContent = "Read more"
    } else {
      // Expand it
      commentParagraphWrapper.classList.remove("collapsed")
      commentParagraphWrapper.classList.add("expanded")
      toggleButton.textContent = "Read less"
    }
  }
</script>
