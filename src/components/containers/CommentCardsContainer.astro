---
import { formatCommentPostDate } from "../../js/utils/formatters"
import Card from "../cards/Card.astro"
import Heading from "../headings/Heading.astro"
import Footer from "../footers/Footer.astro"
import LikesAndRatingsContainer from "./LikesAndRatingsContainer.astro"
import CommentCardBodyContainer from "../containers/CommentCardBodyContainer.astro"
const { class: className, id, comments = [] } = Astro.props
---

<div class="flex flex-col mt-12">
  <Heading variant="single_view_sub_heading">Comments</Heading>
  <div class={`${className} flex flex-wrap gap-7 mt-6`} id={id}>
    {
      comments.length > 0 ? (
        comments.map((comment, index) => (
          <Card variant="comment" key={index}>
            <Heading variant="comment_sub_heading">
              <img
                slot="leading"
                src={comment.user.user_profile_image}
                alt={comment.user.user_name}
                class="h-[100px] w-[100px] rounded-full"
              />
              <div slot="title" class="flex flex-col username-and-comment-time">
                <span class="username italic text-gray-400">
                  {comment.user.user_name}
                </span>
                <p class="text-(--secondary-text-color)">
                  Posted{" "}
                  <span>{formatCommentPostDate(comment.created_at)}</span>
                </p>
              </div>
            </Heading>

            <CommentCardBodyContainer>
              <Heading slot="heading" variant="comment_heading">
                {comment.title}
              </Heading>
              <p slot="paragraph">{comment.body}</p>
              <button
                slot="actions"
                class="read-more-btn text-(--secondary-text-color) cursor-pointer"
                type="button"
                id="read_more_btn"
              >
                Read more
              </button>
            </CommentCardBodyContainer>

            <Footer variant="comment_card_footer">
              <LikesAndRatingsContainer
                likeAmount={comment.likeAmount}
                starsCount={comment.rating}
                mealRatingNumber={comment.rating}
                maximumRatingNumber={comment.maximumRatingNumber}
              />
            </Footer>
          </Card>
        ))
      ) : (
        <p class="text-(--secondary-text-color)">No comments</p>
      )
    }
  </div>
</div>
