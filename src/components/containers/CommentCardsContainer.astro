---
import { formatCommentPostDate } from "../../js/utils/formatters"
import Card from "../cards/Card.astro"
import Heading from "../headings/Heading.astro"
import Footer from "../footers/Footer.astro"
import LikesAndRatingsContainer from "./LikesAndRatingsContainer.astro"
import CommentCardBodyContainer from "../containers/CommentCardBodyContainer.astro"
import Button from "../buttons/Button.astro"
import { supabaseClient } from "../../js/supabase/supabase_client"
import { fetchComments } from "../../js/supabase/supabase_methods"

const { comments = [], mealId } = Astro.props
---

<div class="flex flex-col mt-12">
  <Heading variant="single_view_sub_heading">
    <h2>Comments</h2>
  </Heading>
  <div class="comments-section flex flex-wrap gap-7 mt-6" data-meal-id={mealId}>
    {
      comments.length > 0 ? (
        comments.map((comment, index) => (
          <Card
            variant="comment"
            class="comment-card group relative"
            key={index}
            data-id={comment.id}
            data-comment-title={comment.title}
            data-comment-body-text={comment.body}
            data-comment-rating={comment.rating}
          >
            <div
              class="comment-action-buttons-container absolute -right-2 -top-4 flex gap-2 opacity-0 transition-opacity duration-150 ease-in group-hover:opacity-100"
              data-comment-user-id={comment.user.id}
            >
              <Button
                variant="comment_edit_button"
                data-action="edit-comment"
                data-id={comment.id}
              >
                <i class="fas fa-pencil-alt text-xl" />
              </Button>
              <Button
                variant="comment_delete_button"
                data-action="delete-comment"
                data-id={comment.id}
              >
                <i class="fas fa-trash-alt" />
              </Button>
            </div>

            <Heading variant="comment_sub_heading">
              <img
                slot="leading"
                src={comment.user.user_profile_image}
                alt={comment.user.user_name}
                class="h-[100px] w-[100px] rounded-full"
              />
              <div slot="title" class="flex flex-col username-and-comment-time">
                <span class="username italic text-gray-400">
                  {comment.user.user_name}
                </span>
                <p class="text-(--secondary-text-color)">
                  Posted{" "}
                  <span>{formatCommentPostDate(comment.created_at)}</span>
                </p>
              </div>
            </Heading>

            <CommentCardBodyContainer>
              <Heading slot="heading" variant="comment_heading">
                {comment.title}
              </Heading>
              <p slot="paragraph">{comment.body}</p>
              <button
                slot="actions"
                class="read-more-btn text-(--secondary-text-color) cursor-pointer"
                type="button"
                id="read_more_btn"
              >
                Read more
              </button>
            </CommentCardBodyContainer>

            <Footer variant="comment_card_footer">
              <LikesAndRatingsContainer
                likeAmount={comment.likeAmount}
                starsCount={comment.rating}
                mealRatingNumber={comment.rating}
                maximumRatingNumber={comment.maximumRatingNumber}
              />
            </Footer>
          </Card>
        ))
      ) : (
        <p class="text-(--secondary-text-color)">No comments</p>
      )
    }
  </div>
</div>

<script>
  import { supabaseClient } from "../../js/supabase/supabase_client"
  import {
    deleteMealComment,
    editMealComment,
  } from "../../js/supabase/supabase_methods"

  const deleteMealCommentConfirmationDialog = document.querySelector(
    "#confirm_delete_meal_comment_dialog",
  )
  const deleteMealCommentConfirmationDialogConfirmButton =
    deleteMealCommentConfirmationDialog?.querySelector(
      "#confirm_delete_meal_comment_button",
    )
  const deleteMealCommentConfirmationDialogCancelButton =
    deleteMealCommentConfirmationDialog?.querySelector(
      "#cancel_delete_meal_comment_button",
    )
  const confirmDeleteCommentDialogParagraph =
    deleteMealCommentConfirmationDialog?.querySelector("p")

  deleteMealCommentConfirmationDialogConfirmButton?.addEventListener(
    "click",
    handleConfirmDeleteMealComment,
  )
  deleteMealCommentConfirmationDialogCancelButton?.addEventListener(
    "click",
    handleConfirmDeleteMealComment,
  )

  const editCommentFormDialog = document.querySelector("#edit_comment_dialog")
  const editCommentForm =
    editCommentFormDialog?.querySelector("#edit_comment_form")

  const confirmDeleteCommentDialog = document.querySelector(
    "confirm_delete_meal_comment_dialog",
  )
  console.log(confirmDeleteCommentDialog)
  console.log(editCommentForm)
  editCommentForm?.addEventListener("submit", (e) => submitCommentEdit(e))

  // Check authentication and hide/show buttons
  async function checkAuthAndUpdateButtons() {
    const {
      data: { session },
    } = await supabaseClient.auth.getSession()
    const currentUserId = session?.user?.id
    console.log("Current user ID: ", currentUserId)

    const commentActionButtonsContainers = document.querySelectorAll(
      ".comment-action-buttons-container",
    )

    commentActionButtonsContainers?.forEach((container) => {
      const commentUserId = container.getAttribute("data-comment-user-id")
      console.log("Comment user ID: ", commentUserId)

      // Hide buttons if user is NOT the comment author
      if (!currentUserId || currentUserId !== commentUserId) {
        container.style.display = "none"
      }
    })
  }

  // Run on page load
  checkAuthAndUpdateButtons()

  // Event handlers
  const commentActionButtonsContainers = document.querySelectorAll(
    ".comment-action-buttons-container",
  )

  commentActionButtonsContainers?.forEach((container) => {
    container?.addEventListener("click", (e) => handleCommentAction(e))
  })

  function handleCommentAction(e) {
    if (e.target.matches('[data-action="edit-comment"]')) {
      openEditCommentForm(e)
      console.log("Edit comment")
    }

    if (e.target.matches('[data-action="delete-comment"]')) {
      openDeleteCommentConfirmationModal(e)
    }
  }

  // EDITING COMMENT //

  // Open Comment Edit form
  function openEditCommentForm(e) {
    // Display dialog
    editCommentFormDialog?.showModal()

    const commentCard = e.target.closest(".comment-card")
    const commentId = commentCard.dataset.id
    editCommentForm.dataset.id = commentId

    const editCommentFormFieldsObject = {
      commentTitle: "comment_title_input",
      commentBodyText: "comment_text_input",
      commentRating: "comment_rating_input",
    }

    Object.entries(editCommentFormFieldsObject).forEach(
      ([commentKey, inputName]) => {
        const value = commentCard?.dataset[commentKey]
        const input = editCommentForm?.querySelector(`[name="${inputName}"]`)
        if (input) {
          input.value = value ?? "" // sets the initial input value
        }
      },
    )

    populateRatingStarsUI()
  }

  // Populate rating star UI
  function populateRatingStarsUI() {
    const starsContainer = editCommentForm.querySelector(".meal-rating-star")
    if (starsContainer) {
      const starWrappers = starsContainer.querySelectorAll(".star-wrapper")
      const ratingInput = editCommentForm.querySelector(
        '[name="comment_rating_input"]',
      )
      const currentRating = parseFloat(ratingInput.value) || 0
      updateStarDisplay(starWrappers, currentRating)
    }
  }

  function submitCommentEdit(e) {
    e.preventDefault()
    const commentId = editCommentForm.dataset.id
    const commentTitle = editCommentForm.querySelector(
      '[name="comment_title_input"]',
    ).value
    const commentText = editCommentForm.querySelector(
      '[name="comment_text_input"]',
    ).value
    const commentRating =
      parseFloat(
        editCommentForm.querySelector('[name="comment_rating_input"]').value,
      ) || 0

    editMealComment(commentId, commentTitle, commentText, commentRating)

    editCommentFormDialog?.close()
  }

  // DELETING COMMENT //
  function openDeleteCommentConfirmationModal(e) {
    const confirmDeleteMealCommentButton =
      deleteMealCommentConfirmationDialog?.querySelector(
        "#confirm_delete_meal_comment_button",
      )
    confirmDeleteCommentDialogParagraph.textContent =
      "Are you sure you want to delete your comment? This cannot be undone!"
    confirmDeleteMealCommentButton?.setAttribute("data-id", e.target.dataset.id)
    deleteMealCommentConfirmationDialog?.showModal()
  }

  async function handleConfirmDeleteMealComment(e) {
    if (e.target.matches("#cancel_delete_meal_comment_button")) {
      deleteMealCommentConfirmationDialog?.close()
      return
    }

    const deleteButtonId = e.target.dataset.id
    const { data: deleteCommentData, error: deleteCommentError } =
      await deleteMealComment(deleteButtonId)

    if (!deleteCommentData || deleteCommentError) {
      console.error("Error deleting comment: ", deleteCommentError)
    } else {
      document.querySelector(`[data-comment-id="${deleteButtonId}"]`)?.remove()
    }

    deleteMealCommentConfirmationDialog?.close()
  }
</script>
