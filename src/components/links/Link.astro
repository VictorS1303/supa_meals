---
const {
  class: className,
  id,
  href,
  buttonText,
  isYouTubeButton,
  target,
  isSingleViewHeroLink,
  isRegisterLink,
  isMealCardLink,
  isPaginationLink,
  isDashboardOverlayLink,
  isBackLink,
} = Astro.props
---

{
  isSingleViewHeroLink ? (
    <a
      class="absolute top-3 left-3 text-[var(--secondary-text-color)] text-2xl text-white z-[100001] cursor-pointer transition-text duration-150 ease-in hover:text-[var(--secondary-text-color)]"
      href={href}
    >
      <slot />
    </a>
  ) : isRegisterLink ? (
    <a
      class="text-white border-b-2 border-white transition-all duration-100 ease-in hover:text-(--secondary-text-color) hover:border-(--secondary-text-color)"
      href={href}
    >
      {buttonText}
    </a>
  ) : isMealCardLink ? (
    <a
      class="bg-(--secondary-text-color) mt-auto w-fit py-2 px-4 text-white rounded-md transition-opacity duration-150 hover:opacity-90"
      href={href}
    >
      {buttonText}
    </a>
  ) : isPaginationLink ? (
    <a
      class={`${className} prev-btn flex items-center gap-2 px-4 py-2 bg-[#333] text-white rounded-md`}
      href={href}
    >
      <slot />
    </a>
  ) : isBackLink ? (
    <a
      class="absolute top-3 left-3 text-(--secondary-text-color) text-2xl cursor-pointer"
      href={href}
    >
      <i class="fas fa-arrow-left" />
    </a>
  ) : isDashboardOverlayLink ? (
    <a
      class="text-white bg-(--secondary-text-color) px-4 py-3 rounded-md text-xl cursor-pointer transition-opacity duration-150 ease-in hover:opacity-85"
      href={href}
    >
      {buttonText}
    </a>
  ) : (
    ""
  )
}
