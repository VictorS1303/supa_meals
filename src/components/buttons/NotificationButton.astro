---
// @ts-nocheck
import Button from "./Button.astro"
import { fetchNotificationsAmount } from "../../js/supabase/supabase_methods"

const { id, popovertarget, supabaseServerClient } = Astro.props

const session = Astro.locals.session
const currentUserId = session?.user?.id

console.log("SERVER - User ID:", currentUserId)
console.log("SERVER - Has server client:", !!supabaseServerClient)

const notificationsAmount =
  currentUserId && supabaseServerClient
    ? await fetchNotificationsAmount(currentUserId, supabaseServerClient)
    : 0

console.log("SERVER - Initial notifications amount:", notificationsAmount)
console.log("SERVER - User ID:", currentUserId)
---

<Button
  variant="notification_button"
  id={id}
  popovertarget="notifications_list"
  anchor="notifications-button"
>
  <span
    class="notification-counter grid place-content-center absolute text-xs -right-[5px] -top-[3px] bg-(--notification-button-number-bg-color) h-[20px] w-[20px] p-[5px] rounded-full"
    id="notification_counter">{notificationsAmount}</span
  >
  <i class="fa-solid fa-bell"></i>
</Button>

<script>
  import { createPopper } from "@popperjs/core"
  import { supabaseClient } from "../../js/supabase/supabase_client"
  import { updateNotificationsCounter } from "../../js/supabase/realtime_dom_helper_methods.js"
  import { fetchNotificationsAmount } from "../../js/supabase/supabase_methods"
  import { initializeNotificationsRealtime } from "../../js/utils/updaters"

  document.addEventListener("DOMContentLoaded", () => {
    const notificationsButton = document.querySelector("[popovertarget]")
    const notificationsListPopover = document.querySelector(
      ".notifications-list-popover",
    )

    const popperInstance = createPopper(
      notificationsButton,
      notificationsListPopover,
      {
        placement: "bottom-end",
        modifiers: [
          { name: "offset", options: { offset: [0, 8] } },
          {
            name: "flip",
            options: {
              fallbackPlacements: ["bottom-start", "top-end", "top-start"],
            },
          },
          { name: "preventOverflow", options: { padding: 8 } },
        ],
      },
    )

    // // Toggle popover
    notificationsButton.addEventListener("click", togglePopover)

    function togglePopover() {
      notificationsListPopover.classList.toggle("hidden")
      popperInstance.update()
    }

    initializeNotificationsRealtime()
  })
</script>
