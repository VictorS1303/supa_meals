---
import { fetchSingleMealById } from "../../js/meal_fetching.js"
import SingleViewLayout from "../../layouts/SingleViewLayout.astro"

const { id } = Astro.params
const singleMeal = await fetchSingleMealById(id)

// Get the YouTube URL directly from the meal
const videoURL = singleMeal.strYoutube

console.log("Video URL:", videoURL) // Debug log
---

<SingleViewLayout
  title={singleMeal.strMeal}
  src={singleMeal.strMealThumb}
  headingText={singleMeal.strMeal}
  alt={singleMeal.strMealAlternate || "Meal image is missing"}
  href={singleMeal.strYoutube}
  target="_blank"
  meal={singleMeal}
  videoSrc={videoURL}
/>
